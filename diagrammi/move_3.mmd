sequenceDiagram
    participant Client
    participant Route as GameRoutes
    participant Auth as authenticateJWT
    participant Controller as GameController
    participant Base as BaseGameService
    participant PvP as PvPGameService
    participant PvE as PvEGameService
    participant GameRepo as GameRepository
    participant UserRepo as UserRepository
    participant GameDAO as GameDAO
    participant UserDAO as UserDAO
    participant GameDB as Game Model / Games table
    participant UserDB as User Model / Users table
    participant Engine as GameEngine
    participant Sequelize as Sequelize Transaction
    participant ErrorHandler

    Client->>Route: POST /api/games/:id/move
    Route->>Auth: authenticateJWT

    alt JWT mancante o non valido
        Auth-->>ErrorHandler: UNAUTHORIZED
        ErrorHandler-->>Client: 401 JSON error
    else JWT valido
        Auth-->>Route: req.user.id
        Route->>Controller: makeMove(req, res, next)

        Controller->>Base: getGameType(gameId)
        Base->>GameRepo: getById(gameId)
        GameRepo->>GameDAO: fetchSingle(gameId)
        GameDAO->>GameDB: Game.findByPk(gameId)
        GameDB-->>GameDAO: Game | null
        GameDAO-->>GameRepo: Game | null
        GameRepo-->>Base: Game | null

        alt partita non trovata
            Base-->>ErrorHandler: NOT_FOUND
            ErrorHandler-->>Client: 404 JSON error
        else type = PVP
            Base-->>Controller: PVP
            Controller->>PvP: processMove(gameId, userId, x, y)

            PvP->>Sequelize: begin transaction
            PvP->>GameRepo: getById(gameId, transaction, lock)
            GameRepo->>GameDAO: fetchSingle(gameId, transaction, lock)
            GameDAO->>GameDB: Game.findByPk(gameId, transaction, lock)
            GameDB-->>GameDAO: Game
            GameDAO-->>GameRepo: Game
            GameRepo-->>PvP: Game

            alt partita non ACTIVE
                PvP->>Sequelize: rollback
                PvP-->>ErrorHandler: BAD_REQUEST
                ErrorHandler-->>Client: 400 JSON error
            else utente non partecipante
                PvP->>Sequelize: rollback
                PvP-->>ErrorHandler: FORBIDDEN
                ErrorHandler-->>Client: 403 JSON error
            else non è il turno dell'utente
                PvP->>Sequelize: rollback
                PvP-->>ErrorHandler: FORBIDDEN
                ErrorHandler-->>Client: 403 JSON error
            else coordinate non valide o già colpite
                PvP->>Sequelize: rollback
                PvP-->>ErrorHandler: BAD_REQUEST
                ErrorHandler-->>Client: 400 JSON error
            else mossa valida
                PvP->>UserRepo: getUserById(userId, transaction, lock)
                UserRepo->>UserDAO: fetchSingle(userId, transaction, lock)
                UserDAO->>UserDB: User.findByPk(userId, transaction, lock)
                UserDB-->>UserDAO: User
                UserDAO-->>UserRepo: User
                UserRepo-->>PvP: User

                PvP->>Engine: applyMove(targetBoard, { x, y })
                Engine-->>PvP: result, updatedBoard
                PvP->>PvP: aggiunge mossa a state.history

                alt vittoria
                    PvP->>PvP: game.status = FINISHED
                    PvP->>PvP: game.winnerId = userId
                    PvP->>PvP: user.points += 1
                else nessuna vittoria
                    PvP->>PvP: state.currentTurn = avversario
                end

                PvP->>PvP: user.tokenBalance -= MOVE_COST
                PvP->>UserRepo: saveUserChanges(user, transaction)
                UserRepo->>UserDB: user.save({ transaction })

                PvP->>PvP: game.gameState = state
                PvP->>GameRepo: updateGame(game, transaction)
                GameRepo->>GameDAO: updateStateWithTransaction(game, transaction)
                GameDAO->>GameDB: game.save({ transaction })
                GameDB-->>GameDAO: Game aggiornato
                GameDAO-->>GameRepo: Game aggiornato
                GameRepo-->>PvP: Game aggiornato

                PvP->>Sequelize: commit
                PvP-->>Controller: { result, nextTurn, gameStatus, winner }
                Controller-->>Client: 200 JSON result
            end

        else type = PVE
            Base-->>Controller: PVE
            Controller->>PvE: processMove(gameId, userId, x, y)

            PvE->>Sequelize: begin transaction
            PvE->>GameRepo: getById(gameId, transaction, lock)
            GameRepo->>GameDAO: fetchSingle(gameId, transaction, lock)
            GameDAO->>GameDB: Game.findByPk(gameId, transaction, lock)
            GameDB-->>GameDAO: Game
            GameDAO-->>GameRepo: Game
            GameRepo-->>PvE: Game

            alt partita non ACTIVE
                PvE->>Sequelize: rollback
                PvE-->>ErrorHandler: BAD_REQUEST
                ErrorHandler-->>Client: 400 JSON error
            else utente non è player1
                PvE->>Sequelize: rollback
                PvE-->>ErrorHandler: FORBIDDEN
                ErrorHandler-->>Client: 403 JSON error
            else non è il turno dell'utente
                PvE->>Sequelize: rollback
                PvE-->>ErrorHandler: FORBIDDEN
                ErrorHandler-->>Client: 403 JSON error
            else coordinate non valide o già colpite
                PvE->>Sequelize: rollback
                PvE-->>ErrorHandler: BAD_REQUEST
                ErrorHandler-->>Client: 400 JSON error
            else mossa utente valida
                PvE->>UserRepo: getUserById(userId, transaction, lock)
                UserRepo->>UserDAO: fetchSingle(userId, transaction, lock)
                UserDAO->>UserDB: User.findByPk(userId, transaction, lock)
                UserDB-->>UserDAO: User
                UserDAO-->>UserRepo: User
                UserRepo-->>PvE: User

                PvE->>Engine: applyMove(player2Board, { x, y })
                Engine-->>PvE: userAttack
                PvE->>PvE: aggiunge mossa utente a state.history

                alt utente vince
                    PvE->>PvE: game.status = FINISHED
                    PvE->>PvE: game.winnerId = userId
                    PvE->>PvE: user.points += 1
                else IA deve giocare
                    PvE->>Engine: generateIAMove(gridSize, player1Board.shotsReceived)
                    Engine-->>PvE: iaTarget
                    PvE->>Engine: applyMove(player1Board, iaTarget)
                    Engine-->>PvE: iaAttack
                    PvE->>PvE: aggiunge mossa IA a state.history

                    alt IA vince
                        PvE->>PvE: game.status = FINISHED
                        PvE->>PvE: game.winnerId = null
                    end
                end

                PvE->>PvE: user.tokenBalance -= MOVE_COST
                PvE->>UserRepo: saveUserChanges(user, transaction)
                UserRepo->>UserDB: user.save({ transaction })

                PvE->>PvE: game.gameState = state
                PvE->>GameRepo: updateGame(game, transaction)
                GameRepo->>GameDAO: updateStateWithTransaction(game, transaction)
                GameDAO->>GameDB: game.save({ transaction })
                GameDB-->>GameDAO: Game aggiornato
                GameDAO-->>GameRepo: Game aggiornato
                GameRepo-->>PvE: Game aggiornato

                PvE->>Sequelize: commit
                PvE-->>Controller: { userMove, iaMove, currentStatus, winner }
                Controller-->>Client: 200 JSON result
            end

        else type non valido
            Controller-->>ErrorHandler: BAD_REQUEST
            ErrorHandler-->>Client: 400 JSON error
        end
    end